HOST_PORT=8080
WEB_PORT=8080
WEB_HOST=0.0.0.0
LOG_LEVEL=info
DB_PATH=/data/schedule-containers.db
DOCKER_HOST=unix:///var/run/docker.sock

# OIDC (Pocket ID / any OpenID Connect provider)
# All four must be set to enable OIDC login. Leave empty to disable.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=